{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MSIX离线安装器",
  "version": "0.1.1",
  "identifier": "com.luopeichun.msixofflineinstaller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MSIX离线安装器",
        "width": 1220,
        "height": 900,
        "minWidth": 980,
        "minHeight": 760,
        "resizable": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
